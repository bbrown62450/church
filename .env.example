# Copy this file to .env and fill in your values. Never commit .env.

# Optional: app password (if set, users must enter it to use the app; recommended when email sending is enabled)
# APP_PASSWORD=

# Notion (for hymn database)
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Optional: Notion databases for online archive and hymn usage (e.g. when hosting on Streamlit Cloud)
# Create two databases in Notion, add the properties listed in README, connect your integration, then set:
# NOTION_ARCHIVE_DATABASE_ID=
# NOTION_USAGE_DATABASE_ID=

# OpenAI (for liturgy generation)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# --- Email: choose ONE of the two options below ---

# Option A (recommended): per-user "Sign in with your own Gmail" via Google OAuth.
# Each user connects their own Google account and sends from their own mailbox.
# Create an OAuth client in Google Cloud (see README "Connect your Gmail (OAuth)").
# The redirect URI must exactly match the app's URL (registered in Google Cloud).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8501

# Option B (legacy fallback): one shared Gmail App Password for the whole app.
# Used only when the GOOGLE_* variables above are not set.
# Use an App Password, not your normal password: https://myaccount.google.com/apppasswords
# GMAIL_ADDRESS=
# GMAIL_APP_PASSWORD=
